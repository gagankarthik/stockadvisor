# Copy to .env for local development. In Lambda, set these as environment vars.

# ---- Provider API keys ----
FINNHUB_KEY=
ALPHAVANTAGE_KEY=
# OpenAI powers the narrative "Desk Note" (/insight/*). Leave blank to fall back
# to a deterministic numeric summary — the endpoints still work without it.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ---- Artifact store ----
# Local development (default):
MARKETDESK_ARTIFACT_URI=file://.artifacts
# Production (Lambda) — point both the API and the refresh job at the same bucket:
# MARKETDESK_ARTIFACT_URI=s3://my-marketdesk-bucket/prod

# ---- Optional overrides ----
# MARKETDESK_INDICES=["S&P 500","NASDAQ-100"]
# MARKETDESK_PRICE_PERIOD=2y
# MARKETDESK_HORIZON_DAYS=21
# MARKETDESK_ML_BLEND_WEIGHT=0.35
# MARKETDESK_CORS_ORIGINS=["https://app.example.com"]
